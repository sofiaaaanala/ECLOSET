generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id Int @id @default(autoincrement())

  email String @unique

  username String @unique

  password String

  zona String?

  estilo_ropa String?

  preferencias_colores String?

  talle String?

  foto_perfil String? @default("/default-avatar.png")

  reputacion Float? @default(0)

  preferencias_completadas Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  prendas Prenda[]

  outfits Outfit[]

  @@map("users")
}

model Prenda {
  id_prenda Int @id @default(autoincrement())

  nombre String

  tipo String

  color String

  temporada String?

  etiquetas String?

  marca String?

  talle String?

  imagen_url String?

  imagen_fileId String?

  descripcion String?

  fecha_venta DateTime?

  precio Float?

  descuento Float? @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  id_usuario Int

  usuario User @relation(fields: [id_usuario], references: [id])

  outfits Outfit[]

  @@map("prendas")
}

model Outfit {
  id_output Int @id @default(autoincrement())

  nombre String

  categoria String?

  descripcion String?

  temporada String?

  imagen_url String?

  fecha_creacion DateTime @default(now())

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  id_usuario Int

  usuario User @relation(fields: [id_usuario], references: [id])

  prendas Prenda[]

  @@map("outfits")
}
